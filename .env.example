# Auth0 Configuration
# Get these values from your Auth0 Dashboard: https://manage.auth0.com/

# Your Auth0 Domain (e.g., dev-abc123.us.auth0.com)
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com

# Your Auth0 Application Client ID
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# Auth0 API Audience Identifier
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# API URL for backend integration
VITE_API_URL=http://localhost:3000
